{
  "$schema": "https://opencode.ai/config.json",
  "permission": {
    "bash": {
      "*": "ask",
      "gh api *-X*": "ask",
      "which *": "allow",
      "* --help": "allow",
      "jq *": "allow",
      "head *" : "allow",
      "true *": "allow",
      "tail *" : "allow",
      "sort *" : "allow",
      "find *" : "allow",
      "tree *" : "allow",
      "rg *" : "allow",
      "base64 *" : "allow",
      "command *" : "allow",
      "grep *" : "allow",
      "awk *" : "allow",
      "cat *" : "allow",
      "echo *": "allow",
      "ls *": "allow",
      "docker *": "allow",
      "python *": "allow",
      "python3 *": "allow",
      "pytest *": "allow",
      "node *": "allow",
      "just *": "allow",
      "xargs *": "allow",
      "wc *": "allow",
      "acli * view *": "allow",
      "acli * search *": "allow",
      "acli * list *": "allow",
      "git branch *": "allow",
      "git log *": "allow",
      "git diff *": "allow",
      "git fetch *": "allow",
      "git merge-base *":"allow",
      "git status *":"allow",
      "git show *":"allow",
      "git remote -v *": "allow",
      "git ls-tree *": "allow",
      "gh * status *": "allow",
      "gh * view *": "allow",
      "gh * diff *": "allow",
      "gh api *": "allow",
      "sentry * view": "allow",
  
    }
  }
}
