# Claude Code API Configuration
# Copy this file to ../../.env.claude and fill in your values

# Required: Your Anthropic API key
ANTHROPIC_API_KEY=your_api_key_here

# Optional: Custom API endpoint (defaults to https://api.anthropic.com)
# ANTHROPIC_API_URL=https://api.anthropic.com

# Optional: Default model to use (sonnet, opus, haiku)
# CLAUDE_DEFAULT_MODEL=sonnet

# Optional: Organization ID (for enterprise users)
# ANTHROPIC_ORG_ID=your_org_id

# Optional: Max tokens for responses
# ANTHROPIC_MAX_TOKENS=4096

# Optional: Enable debug mode
# CLAUDE_DEBUG=false
