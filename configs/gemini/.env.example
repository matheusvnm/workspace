# Gemini CLI API Configuration
# Copy this file to ../../.env.gemini and fill in your values

# Required: Your Google AI API key
GEMINI_API_KEY=your_api_key_here

# Optional: Google Cloud Project ID
# GOOGLE_CLOUD_PROJECT=your_project_id

# Optional: Model to use (gemini-pro, gemini-pro-vision, etc.)
# GEMINI_MODEL=gemini-pro

# Optional: Temperature for responses (0.0 to 1.0)
# GEMINI_TEMPERATURE=0.7

# Optional: Max output tokens
# GEMINI_MAX_TOKENS=2048

# Optional: Enable debug mode
# GEMINI_DEBUG=false
