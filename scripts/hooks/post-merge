#!/bin/bash
# Post-merge hook: notify if Claude profiles were updated

if git diff-tree -r --name-only --no-commit-id ORIG_HEAD HEAD | grep -q "^models/claude/profiles/"; then
    echo ""
    echo "Claude profiles updated! Changes synced via symlinks."
    echo ""

    # Check if profile symlinks exist
    if [ ! -L ~/.claude/settings.json ] && [ ! -L ~/.claude/agents ]; then
        echo "Warning: Claude profile symlinks missing."
        echo "Run: claude profile switch <name>"
    fi
fi
